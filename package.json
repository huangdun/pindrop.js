{
  "name": "pindrop.js",
  "version": "0.1.19",
  "description": "Drop-in comment overlay for any web page. Pin comments, threaded replies, and share via JSON export/import.",
  "type": "module",
  "main": "dist/pindrop.umd.js",
  "module": "dist/pindrop.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pindrop.es.js",
      "require": "./dist/pindrop.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./dist/style.css": "./dist/style.css"
  },
  "author": "Dun Huang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huangdun/pindrop.js.git"
  },
  "bin": {
    "pindrop": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "comments",
    "annotation",
    "overlay",
    "review",
    "feedback",
    "figma",
    "prototype"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^25.5.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
